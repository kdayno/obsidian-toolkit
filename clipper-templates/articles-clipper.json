{
	"schemaVersion": "0.1.0",
	"name": "Articles",
	"behavior": "create",
	"noteContentFormat": "> [!info] ## tldr\n> {{\"write a <350 character summary of what this article is about and key insights covered in lowercase\"}}\n\n```table-of-contents\n```\n\n{{content}}",
	"properties": [
		{
			"name": "created",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "created datetime",
			"value": "",
			"type": "datetime"
		},
		{
			"name": "updated datetime",
			"value": "",
			"type": "datetime"
		},
		{
			"name": "tags",
			"value": "articles, read",
			"type": "multitext"
		},
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "url",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "author",
			"value": "{{author|split:\\\", \\\"|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "published",
			"value": "{{published}}",
			"type": "date"
		},
		{
			"name": "description",
			"value": "{{description}}",
			"type": "text"
		}
	],
	"triggers": [
		"/^https:\\/\\/[^\\/]+\\.substack\\.com\\/.*/"
	],
	"noteNameFormat": "{{title}}",
	"path": "03-information-library/articles"
}
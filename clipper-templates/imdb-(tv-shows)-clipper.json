{
	"schemaVersion": "0.1.0",
	"name": "IMDB (tv shows)",
	"behavior": "create",
	"noteContentFormat": "# Plot\n---\n{{schema:description}}\n\n> [!NOTE] # Notes\n> Contents",
	"properties": [
		{
			"name": "created",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "created datetime",
			"value": "",
			"type": "datetime"
		},
		{
			"name": "updated datetime",
			"value": "",
			"type": "datetime"
		},
		{
			"name": "tags",
			"value": "tv-shows, review, watched, watching",
			"type": "multitext"
		},
		{
			"name": "categories",
			"value": "[[TV Shows]]",
			"type": "multitext"
		},
		{
			"name": "genre",
			"value": "{{schema:genre|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "release year",
			"value": "{{schema:datePublished|split:\\\"-\\\"|slice:0,1}}",
			"type": "text"
		},
		{
			"name": "plot",
			"value": "{{schema:description}}",
			"type": "text"
		},
		{
			"name": "director",
			"value": "{{selector:[data-testid=\\\"title-pc-principal-credit\\\"]:first-child a|unique|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "scoreImdb",
			"value": "{{schema:aggregateRating.ratingValue}}",
			"type": "number"
		},
		{
			"name": "cast",
			"value": "{{selector:.ipc-inline-list a[href*='name']|unique|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "cover",
			"value": "{{schema:image}}",
			"type": "text"
		},
		{
			"name": "imdbId",
			"value": "{{meta:property:imdb:pageConst}}",
			"type": "text"
		},
		{
			"name": "last watched",
			"value": "",
			"type": "text"
		},
		{
			"name": "my rating",
			"value": "",
			"type": "number"
		}
	],
	"triggers": [
		"/^https:\\/\\/www\\.imdb\\.com\\/title\\/tt\\d+(?!\\/reference\\/)(\\/[^\\s]*)?$/"
	],
	"noteNameFormat": "{{schema:name}}",
	"path": "05-collections/movies+tv-shows"
}